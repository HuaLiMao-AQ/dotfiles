# local.zsh.example：本机私有配置示例
# 复制为 local.zsh 后即可生效，local.zsh 不会被提交到 git

# 私有 PATH
# path_prepend_if_exists "$HOME/work/bin"

# 私有环境变量
# export OPENAI_API_KEY="sk-..."
# export GITHUB_TOKEN="ghp_..."

# 工作机别名
# alias work='cd ~/work && nvim .'

# 代理（按需开关）
# export http_proxy="http://127.0.0.1:7890"
# export https_proxy="$http_proxy"
# export all_proxy="socks5://127.0.0.1:7890"

# direnv / mise / 1password CLI 等本机工具初始化
# command_exists direnv && eval "$(direnv hook zsh)"
# command_exists mise   && eval "$(mise activate zsh)"
