# =============================================================================
# Ghostty 通用配置
# 路径：~/.config/ghostty/config/common.ghostty
# =============================================================================

# -----------------------------------------------------------------------------
# Shell
# -----------------------------------------------------------------------------
shell-integration-features = cursor,sudo,title,ssh-env

# -----------------------------------------------------------------------------
# Font
# -----------------------------------------------------------------------------
font-family = JetBrainsMono Nerd Font
font-family = Maple Mono NF CN
font-size = 15
font-thicken = false

# 字体大小是否跟随上一个窗口/标签
window-inherit-font-size = true

# -----------------------------------------------------------------------------
# Theme / Color
# -----------------------------------------------------------------------------
# theme = Catppuccin Mocha

theme = TokyoNight
# theme = Dracula
# theme = GruvboxDark
# theme = OneHalfDark

window-theme = dark
minimum-contrast = 1.1

window-colorspace = display-p3

# -----------------------------------------------------------------------------
# Window
# -----------------------------------------------------------------------------
background-opacity = 0.94
background-blur = 80

# window-padding-x = 0
# window-padding-y = 0
window-padding-balance = true

# window-width = 120
# window-height = 36
window-save-state = always
window-step-resize = true

# -----------------------------------------------------------------------------
# Tabs / Splits
# -----------------------------------------------------------------------------
window-new-tab-position = current
split-divider-color = #45475a
unfocused-split-opacity = 0.85

# -----------------------------------------------------------------------------
# Cursor
# -----------------------------------------------------------------------------
cursor-style = block
cursor-style-blink = true
cursor-click-to-move = true

# -----------------------------------------------------------------------------
# Scrollback
# -----------------------------------------------------------------------------
scrollback-limit = 100000

# -----------------------------------------------------------------------------
# Clipboard / Mouse
# -----------------------------------------------------------------------------
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
mouse-hide-while-typing = true

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify,no-bell

# -----------------------------------------------------------------------------
# Keybindings
# -----------------------------------------------------------------------------
keybind = cmd+t=new_tab
keybind = cmd+n=new_window
keybind = cmd+w=close_surface
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

keybind = cmd+shift+[=previous_tab
keybind = cmd+shift+]=next_tab

keybind = cmd+enter=toggle_fullscreen
keybind = cmd+shift+,=reload_config

keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size

# 分屏移动
keybind = cmd+opt+h=goto_split:left
keybind = cmd+opt+j=goto_split:bottom
keybind = cmd+opt+k=goto_split:top
keybind = cmd+opt+l=goto_split:right

confirm-close-surface = true
